From cba4837057b4752d42a3518e89b0e0e08460baca Mon Sep 17 00:00:00 2001
From: Andrew Udvare <audvare@gmail.com>
Date: Wed, 13 May 2026 14:13:34 -0400
Subject: [PATCH 2/2] chd_stream: guard DVD CHD support on DVD_METADATA_TAG
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The DVD_METADATA_TAG macro is defined in newer libchdr revisions but
not in older system-packaged libchdr (e.g., dev-libs/libchdr-0.2 in
Gentoo's ::guru, dated 2023). Without the guard, chd_stream.c fails
to compile against older system libchdr with an "undeclared" error.

Wrap the DVD-metadata read block in #ifdef DVD_METADATA_TAG so the
file compiles against either bundled or older system libchdr. When
the tag is unavailable, DVD CHD support gracefully degrades — only
DVD-format CHDs are affected; CD/GD-ROM CHDs still work.

Companion to the HAVE_SYSTEM_LIBCHDR=1 build mode added in the
previous commit.

Signed-off-by: Andrew Udvare <audvare@gmail.com>
---
 libretro-common/streams/chd_stream.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/libretro-common/streams/chd_stream.c b/libretro-common/streams/chd_stream.c
index 96b3f6e166..ce74aba606 100644
--- a/libretro-common/streams/chd_stream.c
+++ b/libretro-common/streams/chd_stream.c
@@ -129,6 +129,7 @@ chdstream_get_meta(chd_file *chd, int idx, metadata_t *md)
       return true;
    }
 
+#ifdef DVD_METADATA_TAG
    err = chd_get_metadata(chd, DVD_METADATA_TAG, idx, meta,
          sizeof(meta), &meta_size, NULL, NULL);
 
@@ -138,6 +139,7 @@ chdstream_get_meta(chd_file *chd, int idx, metadata_t *md)
       strlcpy(md->type, "DVD", sizeof(md->type));
       return true;
    }
+#endif
 
    return false;
 }
