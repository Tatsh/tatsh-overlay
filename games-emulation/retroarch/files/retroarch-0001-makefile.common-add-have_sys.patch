From 93fe4be1177006e667aa4feade087698862704f3 Mon Sep 17 00:00:00 2001
From: Andrew Udvare <audvare@gmail.com>
Date: Wed, 13 May 2026 14:00:05 -0400
Subject: [PATCH 1/2] Makefile.common: add HAVE_SYSTEM_LIBCHDR opt-in to use
 system libchdr
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

When HAVE_SYSTEM_LIBCHDR=1 is passed to make, retroarch links against
the system libchdr (dev-libs/libchdr) via pkg-config rather than
compiling the bundled deps/libchdr copy. Defaults to off so existing
build configurations are unaffected.

This also makes the bundled libchdr_flac.c HAVE_DR_FLAC include-guard
bug (upstream issue #18370) disappear for system-libchdr users, since
the bundled libchdr_flac.c is no longer compiled — the system libchdr
ships its own libchdr_flac with correct symbol resolution.

Distributors (e.g., Gentoo via dev-libs/libchdr in ::guru) need this
so security fixes to libchdr reach the binary without rebuilding from
the bundled copy, and so the build doesn't break when system libFLAC
is preferred over the builtin.

Consumers of libchdr headers (chd_stream.c uses #include <libchdr/chd.h>)
resolve to the system path automatically since /usr/include is in the
default include search path and the bundled headers under
libretro-common/include/libchdr/ are expected to be removed by the
packager (e.g., via src_prepare rm) when HAVE_SYSTEM_LIBCHDR=1.

Signed-off-by: Andrew Udvare <audvare@gmail.com>
---
 Makefile.common | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/Makefile.common b/Makefile.common
index 57dabf5eac..e0c8e3c2d4 100644
--- a/Makefile.common
+++ b/Makefile.common
@@ -2054,8 +2054,13 @@ ifeq ($(HAVE_ZLIB_COMMON), 1)
    HAVE_COMPRESSION = 1
 
    ifeq ($(HAVE_CHD), 1)
-      INCLUDE_DIRS += -I$(LIBRETRO_COMM_DIR)/formats/libchdr
       DEFINES += -DHAVE_CHD -DWANT_SUBCODE -DWANT_RAW_DATA_SECTOR
+ifeq ($(HAVE_SYSTEM_LIBCHDR),1)
+      DEFINES += $(shell pkg-config --cflags libchdr)
+      LIBS    += $(shell pkg-config --libs libchdr)
+else
+      INCLUDE_DIRS += -I$(LIBRETRO_COMM_DIR)/formats/libchdr
+endif
       ifeq ($(HAVE_STATIC_CORES), 1)
          DEFINES += -Dbitstream_overflow=retroarch_internal_bitstream_overflow
          DEFINES += -Dcreate_bitstream=retroarch_internal_create_bitstream
@@ -2147,11 +2152,13 @@ ifeq ($(HAVE_ZLIB_COMMON), 1)
          DEFINES += -Dcdzs_codec_free=retroarch_internal_cdzs_codec_free
          DEFINES += -Dcdzs_codec_decompress=retroarch_internal_cdzs_codec_decompress
       endif
+      OBJ     += $(LIBRETRO_COMM_DIR)/streams/chd_stream.o
+
+ifneq ($(HAVE_SYSTEM_LIBCHDR),1)
       OBJ     += $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_bitstream.o \
                  $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_cdrom.o \
                  $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_chd.o \
                  $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_huffman.o \
-                 $(LIBRETRO_COMM_DIR)/streams/chd_stream.o \
                  $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_zlib.o
 
       ifeq ($(HAVE_FLAC),1)
@@ -2166,6 +2173,7 @@ ifeq ($(HAVE_ZLIB_COMMON), 1)
       ifeq ($(HAVE_ZSTD), 1)
          OBJ += $(LIBRETRO_COMM_DIR)/formats/libchdr/libchdr_zstd.o
       endif
+endif
    endif
 endif
 
