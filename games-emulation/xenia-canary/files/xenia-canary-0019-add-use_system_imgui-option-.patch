 # imgui
 # ==============================================================================
-add_library(imgui STATIC
-  imgui/imgui.cpp
-  imgui/imgui_demo.cpp
-  imgui/imgui_draw.cpp
-  imgui/imgui_tables.cpp
-  imgui/imgui_widgets.cpp
-)
-target_include_directories(imgui PUBLIC imgui PRIVATE stb)
+if(USE_SYSTEM_IMGUI)
+  find_package(PkgConfig REQUIRED)
+  pkg_check_modules(IMGUI REQUIRED imgui)
+  add_library(imgui INTERFACE)
+  target_include_directories(imgui SYSTEM INTERFACE ${IMGUI_INCLUDE_DIRS})
+  target_link_libraries(imgui INTERFACE ${IMGUI_LDFLAGS})
+  target_compile_options(imgui INTERFACE ${IMGUI_CFLAGS_OTHER})
+else()
+  add_library(imgui STATIC
+    imgui/imgui.cpp
+    imgui/imgui_demo.cpp
+    imgui/imgui_draw.cpp
+    imgui/imgui_tables.cpp
+    imgui/imgui_widgets.cpp
