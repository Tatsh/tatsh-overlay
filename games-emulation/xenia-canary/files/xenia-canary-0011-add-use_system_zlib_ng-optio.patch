From 2f72485e9d2d508e452e4019c00d4810ac4bdc4c Mon Sep 17 00:00:00 2001
From: Andrew Udvare <audvare@gmail.com>
Date: Sun, 8 Feb 2026 19:33:01 -0500
Subject: [PATCH 11/23] Add USE_SYSTEM_ZLIB_NG option for system zlib-ng

- third_party/CMakeLists.txt: link system zlib-ng (pkg-config) when
  USE_SYSTEM_ZLIB_NG is set, else build the bundled copy.
- src/xenia/base/zlib_ng_include.h: new wrapper selecting <zlib-ng.h> when
  XENIA_USE_SYSTEM_ZLIB_NG is defined.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 src/xenia/base/zlib_ng_include.h | 11 +++++++++++
 src/xenia/kernel/util/xlast.cc   |  2 +-
 third_party/CMakeLists.txt       | 12 ++++++++++++
 3 files changed, 24 insertions(+), 1 deletion(-)
 create mode 100644 src/xenia/base/zlib_ng_include.h

diff --git a/src/xenia/base/zlib_ng_include.h b/src/xenia/base/zlib_ng_include.h
new file mode 100644
index 000000000..035e25358
--- /dev/null
+++ b/src/xenia/base/zlib_ng_include.h
@@ -0,0 +1,11 @@
+// Wrapper so Xenia can use either bundled zlib-ng or system libz-ng (XENIA_USE_SYSTEM_ZLIB_NG).
+#ifndef XENIA_BASE_ZLIB_NG_INCLUDE_H_
+#define XENIA_BASE_ZLIB_NG_INCLUDE_H_
+
+#ifdef XENIA_USE_SYSTEM_ZLIB_NG
+#include <zlib-ng.h>
+#else
+#include "third_party/zlib-ng/zlib-ng.h"
+#endif
+
+#endif  // XENIA_BASE_ZLIB_NG_INCLUDE_H_
diff --git a/src/xenia/kernel/util/xlast.cc b/src/xenia/kernel/util/xlast.cc
index 20b7c878d..d5e8b9c85 100644
--- a/src/xenia/kernel/util/xlast.cc
+++ b/src/xenia/kernel/util/xlast.cc
@@ -8,7 +8,7 @@
  */
 
 #include "xenia/kernel/util/xlast.h"
-#include "third_party/zlib-ng/zlib-ng.h"
+#include "xenia/base/zlib_ng_include.h"
 #include "xenia/base/filesystem.h"
 #include "xenia/base/logging.h"
 #include "xenia/base/string_util.h"
diff --git a/third_party/CMakeLists.txt b/third_party/CMakeLists.txt
index 09531df04..555b6c692 100644
--- a/third_party/CMakeLists.txt
+++ b/third_party/CMakeLists.txt
@@ -343,6 +343,17 @@ endif()
 # ==============================================================================
 # zlib-ng
 # ==============================================================================
+if(USE_SYSTEM_ZLIB_NG)
+  find_package(PkgConfig REQUIRED)
+  pkg_check_modules(ZLIB_NG REQUIRED zlib-ng)
+  add_library(zlib-ng INTERFACE)
+  target_include_directories(zlib-ng SYSTEM INTERFACE ${ZLIB_NG_INCLUDE_DIRS})
+  target_link_libraries(zlib-ng INTERFACE ${ZLIB_NG_LDFLAGS})
+  target_compile_options(zlib-ng INTERFACE ${ZLIB_NG_CFLAGS_OTHER})
+endif()
+
+# Build the bundled copy only when not using the system library.
+if(NOT USE_SYSTEM_ZLIB_NG)
 # Generate headers if missing
 set(_zlibng_needs_configure FALSE)
 foreach(_hdr zlib-ng.h zconf-ng.h zlib_name_mangling-ng.h gzread.c)
@@ -425,6 +436,7 @@ else()
   endif()
 endif()
 target_include_directories(zlib-ng PUBLIC zlib-ng)
+endif()  # NOT USE_SYSTEM_ZLIB_NG
 
 # ==============================================================================
 # libusb (Windows only)
