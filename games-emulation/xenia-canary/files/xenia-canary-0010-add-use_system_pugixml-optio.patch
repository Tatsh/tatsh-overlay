From 35d35e02a862bdbefc6791a33a3b5d280ceb130f Mon Sep 17 00:00:00 2001
From: Andrew Udvare <audvare@gmail.com>
Date: Sun, 8 Feb 2026 19:20:56 -0500
Subject: [PATCH 10/23] Add USE_SYSTEM_PUGIXML option for system libpugixml

- third_party/CMakeLists.txt: link system pugixml (pkg-config) when
  USE_SYSTEM_PUGIXML is set, else build the bundled copy.
- src/xenia/base/pugixml_include.h: new wrapper selecting <pugixml.hpp> when
  XENIA_USE_SYSTEM_PUGIXML is defined.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 src/xenia/base/pugixml_include.h | 11 +++++++++++
 src/xenia/kernel/util/xlast.h    |  2 +-
 third_party/CMakeLists.txt       | 17 +++++++++++++----
 3 files changed, 25 insertions(+), 5 deletions(-)
 create mode 100644 src/xenia/base/pugixml_include.h

diff --git a/src/xenia/base/pugixml_include.h b/src/xenia/base/pugixml_include.h
new file mode 100644
index 000000000..7b9ad839c
--- /dev/null
+++ b/src/xenia/base/pugixml_include.h
@@ -0,0 +1,11 @@
+// Wrapper so Xenia can use either bundled pugixml or system libpugixml (XENIA_USE_SYSTEM_PUGIXML).
+#ifndef XENIA_BASE_PUGIXML_INCLUDE_H_
+#define XENIA_BASE_PUGIXML_INCLUDE_H_
+
+#ifdef XENIA_USE_SYSTEM_PUGIXML
+#include <pugixml.hpp>
+#else
+#include "third_party/pugixml/src/pugixml.hpp"
+#endif
+
+#endif  // XENIA_BASE_PUGIXML_INCLUDE_H_
diff --git a/src/xenia/kernel/util/xlast.h b/src/xenia/kernel/util/xlast.h
index bc2e34b7f..0736b2053 100644
--- a/src/xenia/kernel/util/xlast.h
+++ b/src/xenia/kernel/util/xlast.h
@@ -16,7 +16,7 @@
 #include <string>
 #include <vector>
 
-#include "third_party/pugixml/src/pugixml.hpp"
+#include "xenia/base/pugixml_include.h"
 #include "xenia/xbox.h"
 
 namespace xe {
diff --git a/third_party/CMakeLists.txt b/third_party/CMakeLists.txt
index eef1614a8..09531df04 100644
--- a/third_party/CMakeLists.txt
+++ b/third_party/CMakeLists.txt
@@ -213,10 +213,19 @@ target_link_libraries(mspack PUBLIC xenia-base)
 # ==============================================================================
 # pugixml
 # ==============================================================================
-add_library(pugixml STATIC
-  pugixml/src/pugixml.cpp
-)
-target_include_directories(pugixml PUBLIC pugixml/src)
+if(USE_SYSTEM_PUGIXML)
+  find_package(PkgConfig REQUIRED)
+  pkg_check_modules(PUGIXML REQUIRED pugixml)
+  add_library(pugixml INTERFACE)
+  target_include_directories(pugixml SYSTEM INTERFACE ${PUGIXML_INCLUDE_DIRS})
+  target_link_libraries(pugixml INTERFACE ${PUGIXML_LDFLAGS})
+  target_compile_options(pugixml INTERFACE ${PUGIXML_CFLAGS_OTHER})
+else()
+  add_library(pugixml STATIC
+    pugixml/src/pugixml.cpp
+  )
+  target_include_directories(pugixml PUBLIC pugixml/src)
+endif()
 
 # ==============================================================================
 # snappy
-- 
