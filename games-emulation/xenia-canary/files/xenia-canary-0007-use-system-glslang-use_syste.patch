+++ b/third_party/CMakeLists.txt
@@ -156,17 +156,25 @@ endif()
 # glslang-spirv (not needed on macOS — no Vulkan/SPIR-V backend)
 # ==============================================================================
 if(NOT APPLE)
-  file(GLOB _glslang_spirv_cpp "glslang/SPIRV/*.cpp")
-  file(GLOB _glslang_spirv_h "glslang/SPIRV/*.h")
-  file(GLOB _glslang_spirv_hpp "glslang/SPIRV/*.hpp11")
-  list(FILTER _glslang_spirv_cpp EXCLUDE REGEX "GlslangToSpv\\.cpp$")
-  add_library(glslang-spirv STATIC
-    ${_glslang_spirv_cpp}
-    ${_glslang_spirv_h}
-    ${_glslang_spirv_hpp}
-    glslang/glslang/Include/visibility.h
-  )
-  target_include_directories(glslang-spirv PUBLIC glslang)
+  if(USE_SYSTEM_GLSLANG)
+    # System glslang exposes its SPIR-V builder via the glslang::SPIRV target
+    # (CMake package config). It transitively pulls glslang and SPIRV-Tools.
+    find_package(glslang CONFIG REQUIRED)
+    add_library(glslang-spirv INTERFACE)
+    target_link_libraries(glslang-spirv INTERFACE glslang::SPIRV glslang::glslang)
+  else()
+    file(GLOB _glslang_spirv_cpp "glslang/SPIRV/*.cpp")
+    file(GLOB _glslang_spirv_h "glslang/SPIRV/*.h")
+    file(GLOB _glslang_spirv_hpp "glslang/SPIRV/*.hpp11")
+    list(FILTER _glslang_spirv_cpp EXCLUDE REGEX "GlslangToSpv\\.cpp$")
+    add_library(glslang-spirv STATIC
+      ${_glslang_spirv_cpp}
+      ${_glslang_spirv_h}
+      ${_glslang_spirv_hpp}
+      glslang/glslang/Include/visibility.h
+    )
+    target_include_directories(glslang-spirv PUBLIC glslang)
+  endif()
 endif()
 
