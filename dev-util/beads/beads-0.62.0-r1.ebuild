DESCRIPTION="Distributed graph issue tracker for AI agents, powered by Dolt"
HOMEPAGE="https://github.com/steveyegge/beads"
SRC_URI="https://github.com/steveyegge/${PN}/archive/refs/tags/v${PV}.tar.gz -> ${P}.tar.gz
	${EGO_SUM_SRC_URI}"

LICENSE="MIT"
SLOT="0"
KEYWORDS="~amd64"
IUSE="test"
RESTRICT="mirror !test? ( test )"

DEPEND="dev-libs/icu"
RDEPEND="${DEPEND}
	dev-db/dolt"

src_compile() {
	CGO_ENABLED=1 go build -ldflags="-X main.Build=v${PV}" -o bd ./cmd/bd || die
}

src_install() {
	dobin bd
	dosym bd /usr/bin/beads
	einstalldocs
}

src_test() {
	go test ./... || die
}
