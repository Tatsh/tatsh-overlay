{
  "author": "Andrew Udvare <audvare@gmail.com>",
  "cspell": {
    "cache": {
      "useCache": true
    },
    "dictionaryDefinitions": [
      {
        "name": "main",
        "path": ".vscode/dictionary.txt"
      }
    ],
    "enableFileTypes": {
      "*": true
    },
    "enableGlobDot": true,
    "files": ["*"],
    "ignorePaths": [
      "*.1",
      "*.csv",
      "*.har",
      "*.lock",
      "*.patch",
      ".git/**",
      ".vscode/extensions.json",
      ".yarn/**/*.cjs",
      "Manifest",
      "dist/**",
      "man/**",
      "phase*.json"
    ],
    "language": "en-GB",
    "languageSettings": [
      {
        "dictionaries": ["main"],
        "languageId": "*"
      }
    ],
    "useGitignore": true
  },
  "description": "Personal Gentoo overlay.",
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "cspell": "^9.8.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-toml": "^2.0.6",
    "pyright": "^1.1.409"
  },
  "engines": {
    "node": ">=20.0"
  },
  "files": ["LICENSE", "README.md"],
  "homepage": "https://tatsh.github.io/tatsh-overlay/",
  "keywords": ["gentoo", "overlay"],
  "license": "MIT",
  "markdownlint-cli2": {
    "config": {
      "MD033": {
        "allowed_elements": ["kbd"]
      },
      "default": true,
      "line-length": {
        "code_blocks": false,
        "line_length": 100,
        "tables": false
      }
    }
  },
  "name": "tatsh-overlay",
  "packageManager": "yarn@4.13.0",
  "prettier": {
    "endOfLine": "lf",
    "iniSpaceAroundEquals": true,
    "jsonRecursiveSort": true,
    "overrides": [
      {
        "files": ["package.json"],
        "options": {
          "parser": "json"
        }
      },
      {
        "files": ["*.xml"],
        "options": {
          "useTabs": true
        }
      }
    ],
    "plugins": [
      "@prettier/plugin-xml",
      "prettier-plugin-ini",
      "prettier-plugin-sort-json",
      "prettier-plugin-toml"
    ],
    "printWidth": 100,
    "reorderKeys": true,
    "singleQuote": true
  },
  "repository": "git@github.com:Tatsh/tatsh-overlay.git",
  "scripts": {
    "check-formatting": "prettier -c . && poetry run yapf -prd scripts && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 '**/*.md' '#node_modules'",
    "check-spelling": "cspell --no-progress './**/*'  './**/.*'",
    "format": "prettier -w . && poetry run yapf -ri scripts && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "mypy": "poetry run mypy",
    "qa": "yarn shellcheck && yarn mypy scripts && yarn ruff scripts && yarn check-spelling && yarn check-formatting",
    "ruff": "poetry run ruff check",
    "shellcheck": "shellcheck scripts/*.sh eclass/*.eclass ./*/*/*.ebuild net-dns/pihole-ftl/files/pihole-FTL x11-misc/mimeo/files/mimeo-completion.sh"
  },
  "version": "0.0.0"
}
