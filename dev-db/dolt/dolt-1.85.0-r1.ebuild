DESCRIPTION="Git for data — version-controlled SQL database"
HOMEPAGE="https://github.com/dolthub/dolt https://www.dolthub.com/"
SRC_URI="https://github.com/dolthub/dolt/archive/refs/tags/v${PV}.tar.gz -> ${P}.tar.gz
	${EGO_SUM_SRC_URI}"
S="${WORKDIR}/${P}/go"

LICENSE="Apache-2.0"
SLOT="0"
KEYWORDS="~amd64"
RESTRICT="mirror"

BDEPEND=">=dev-lang/go-1.25.6"
DEPEND="dev-libs/icu"
RDEPEND="${DEPEND}
	acct-user/dolt"
src_compile() {
	CGO_ENABLED=1 go build -trimpath \
		-ldflags="-s -w" \
		-o dolt ./cmd/dolt || die
}

src_install() {
	keepdir /var/lib/dolt
	fowners dolt:dolt /var/lib/dolt
	dobin dolt
	systemd_dounit "${FILESDIR}/${PN}.service"
	einstalldocs
}

pkg_postinst() {
	elog "The dolt system user owns /var/lib/dolt. Initialize a database there before starting the service, for example:"
	elog "  sudo -u dolt -H dolt init"
	elog "Enable and start with: systemctl enable --now dolt.service"
	elog "Default TCP bind is 127.0.0.1:3306 (see upstream docs to change host, port, or use a config file)."
}
